# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/

# Tests, typing, linting
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Environments and secrets
.env
.env.*
!.env.example
.envrc
.venv/
env/
venv/
*.pem
*.key
credentials*.json

# Jupyter
.ipynb_checkpoints/
*.nbconvert.ipynb

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Data: never commit EyePACS or derived bulk datasets
data/
datasets/
Images/
*.zip
*.tar
*.tar.gz
*.7z

# Model and experiment artifacts
artifacts/**
!artifacts/.gitkeep
checkpoints/
weights/
runs/
wandb/
mlruns/
lightning_logs/
*.ckpt
*.pth
*.pt
*.onnx
*.engine

# Generated reports and caches
reports/figures/**
!reports/figures/.gitkeep
outputs/
cache/
.cache/
*.npy
*.npz
*.pkl
*.pickle

# Runtime-generated predictions and manifests
predictions/
manifests/generated/

# Logs
*.log
